# Environment variables — copy to .env and fill in
#
# Skywatcher supports TWO LLM providers. Set ONE of the API keys below:
#   - Gemini: free, but geo-blocked in some countries (e.g. Bangladesh)
#   - DeepSeek: works globally, OpenAI-compatible (https://platform.deepseek.com)
# If both keys are set, DeepSeek takes priority.

# --- Option A: Google Gemini ---
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Model to use (gemini-2.5-flash is the current free-tier model)
GEMINI_MODEL=gemini-2.5-flash

# --- Option B: DeepSeek (recommended if Gemini is geo-blocked) ---
# Get a key at https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# Model to use (deepseek-chat is the standard chat model)
DEEPSEEK_MODEL=deepseek-chat

# Optional: location defaults (latitude, longitude) for pass predictions
# Defaults to a public location if unset
DEFAULT_LAT=40.014984
DEFAULT_LON=-105.270546

# Optional: HTTP timeout for CelesTrak fetches (seconds)
CELESTRAK_TIMEOUT=15
